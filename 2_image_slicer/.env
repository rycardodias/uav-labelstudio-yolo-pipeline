# remove text to use labels
SLICER_UNLABELED_FLAG=--unlabeled

GROUP=006
# Imagens out (in your computer)
SLICER_DATA_ROOT=P:\pampas_repository_groups/group_${GROUP}
# SLICER_DATA_ROOT=P:\pampas_repository_groups/all_minus_006
SLICER_OUT_ROOT=P:\temporaryFiles\_slices_${GROUP}
# SLICER_OUT_ROOT=P:\temporaryFiles\_slices_all_minus_006
SLICER_IMAGES_SUBDIR=.

# JSON 
ANNOTATIONS_HOST_PATH=P:\pampas_repository_groups\
# SLICER_LS_JSON=/ann/group_${GROUP}_labels.json
SLICER_LS_JSON=
# SLICER_LS_JSON=/ann/all_minus_006_labels.json

# Tiling
SLICER_DROP_SMALL=1
SLICER_SLICE_SIZE=640
SLICER_OVERLAP=0.30
SLICER_MIN_VISIBLE=0.30
SLICER_DROP_TINY=4


# Label Studio extern link
PUBLIC_URL=http://localhost:8080
# Caminho web sob /label-studio/files que corresponde ao OUT:
# (como montaste o repo em /label-studio/files/pampas_repository)
LS_ROOT=pampas_repository