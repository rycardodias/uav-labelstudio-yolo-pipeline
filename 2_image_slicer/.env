GROUP=008
# Imagens out (in your computer)
SLICER_DATA_ROOT=../../pampas_repository_groups/group_${GROUP}
SLICER_OUT_ROOT=P:\temporaryFiles\_slices_${GROUP}
SLICER_IMAGES_SUBDIR=.

# JSON 
ANNOTATIONS_HOST_PATH=../../pampas_repository_groups
SLICER_LS_JSON=/ann/group_${GROUP}_labels.json

# Tiling
SLICER_SLICE_SIZE=640
SLICER_OVERLAP=0.20
SLICER_MIN_VISIBLE=0.30
SLICER_DROP_TINY=4


# Label Studio extern link
PUBLIC_URL=http://localhost:8080
# Caminho web sob /label-studio/files que corresponde ao OUT:
# (como montaste o repo em /label-studio/files/pampas_repository)
LS_ROOT=pampas_repository